---
/**
 * Header — Componente Astro puro (0 JavaScript enviado al navegador).
 *
 * ¿Por qué NO es un componente React?
 * El header no tiene estado (no hay useState, no hay clicks complejos).
 * La navegación es con links HTML normales.
 * El efecto de backdrop-blur al hacer scroll se hace con CSS puro o
 * un <script> inline mínimo de Astro (NO cuenta como React).
 *
 * En el repo oficial:
 * - Header.astro tiene 7.1KB
 * - Usa backdrop-blur que se activa al pasar 250px de scroll
 * - Tiene hamburger menu para mobile
 *
 * Nosotros hacemos lo mismo pero más simple para empezar.
 *
 * CONCEPTO: <script> en Astro vs React
 * Un <script> dentro de un .astro se ejecuta directamente en el navegador.
 * NO es un componente React, no tiene Virtual DOM, no tiene overhead.
 * Es JavaScript vanilla puro — lo más ligero que existe.
 * Astro lo incluye solo UNA vez, aunque uses el componente en 10 páginas.
 */

const navLinks = [
  { href: "/#boxeadores", label: "Boxeadores" },
  { href: "/#combates", label: "Combates" },
  { href: "/#votar", label: "Votar" },
];
---

<header
  id="main-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between">
    <!-- Logo / Nombre -->
    <a href="/" class="font-display text-2xl text-velada-gold uppercase tracking-wider hover:text-velada-gold-light transition-colors">
      La Velada VI
    </a>

    <!-- Links de navegación (desktop) -->
    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="text-sm uppercase tracking-wider text-zinc-400 hover:text-velada-gold transition-colors duration-200"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Botón mobile (hamburger) -->
    <button
      id="mobile-menu-btn"
      class="md:hidden text-zinc-400 hover:text-velada-gold transition-colors"
      aria-label="Abrir menú de navegación"
      aria-expanded="false"
    >
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Menú mobile -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-velada-border bg-velada-dark/95 backdrop-blur-xl"
  >
    <ul class="flex flex-col px-4 py-4 gap-4">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="block text-sm uppercase tracking-wider text-zinc-400 hover:text-velada-gold transition-colors"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<!--
  Script inline de Astro — NO es React, es vanilla JS.
  Se ejecuta una sola vez cuando la página carga.
  Dos responsabilidades:
  1. Backdrop blur al hacer scroll (como el repo oficial)
  2. Toggle del menú mobile
-->
<script>
  const header = document.getElementById("main-header");
  const menuBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");

  // Backdrop blur al hacer scroll (igual que el repo oficial a 250px)
  window.addEventListener("scroll", () => {
    if (!header) return;
    if (window.scrollY > 100) {
      header.classList.add("bg-velada-dark/90", "backdrop-blur-xl", "border-b", "border-velada-border");
    } else {
      header.classList.remove("bg-velada-dark/90", "backdrop-blur-xl", "border-b", "border-velada-border");
    }
  });

  // Toggle menú mobile
  menuBtn?.addEventListener("click", () => {
    const isOpen = mobileMenu?.classList.toggle("hidden") === false;
    menuBtn.setAttribute("aria-expanded", String(isOpen));
  });

  // Cerrar menú al clickar un link
  mobileMenu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      mobileMenu.classList.add("hidden");
      menuBtn?.setAttribute("aria-expanded", "false");
    });
  });
</script>
