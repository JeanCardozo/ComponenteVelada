---
/**
 * Sección de Boxeadores — Grid responsive con animaciones de scroll.
 *
 * CONCEPTO NUEVO: IntersectionObserver + CSS Animations
 *
 * IntersectionObserver es una API del navegador que te avisa
 * cuando un elemento entra o sale del viewport.
 *
 * ¿Por qué NO usar scroll events?
 * - scroll events se disparan 60+ veces por segundo → bloquean el main thread
 * - IntersectionObserver es nativo, optimizado por el navegador, y async
 * - Lighthouse penaliza scroll event listeners pesados
 *
 * PATRÓN: Staggered Animation (animación escalonada)
 * Cada tarjeta aparece con un delay ligeramente mayor que la anterior.
 * Card 1: 0ms, Card 2: 50ms, Card 3: 100ms...
 * Esto crea un efecto "cascada" que es muy profesional.
 * El repo oficial usa este patrón en varios lugares.
 */

import FighterCard from "@components/astro/FighterCard.astro";
import { getAllFighters } from "@lib/fighters";

const fighters = getAllFighters();
---

<section id="boxeadores" class="py-24 px-4">
  <div class="max-w-7xl mx-auto">
    <h2 class="animate-on-scroll font-display text-4xl sm:text-5xl text-velada-gold text-center uppercase mb-4">
      Los Boxeadores
    </h2>
    <p class="animate-on-scroll text-center text-zinc-500 mb-12 max-w-xl mx-auto">
      20 peleadores. 10 combates. Conoce a cada uno de los protagonistas de La Velada VI.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {fighters.map((fighter, index) => (
        <div
          class="animate-on-scroll"
          style={`transition-delay: ${index * 50}ms`}
        >
          <FighterCard fighter={fighter} />
        </div>
      ))}
    </div>
  </div>
</section>

<!--
  IntersectionObserver — Vanilla JS, NO React.
  Observa todos los elementos con clase .animate-on-scroll
  y les añade .is-visible cuando entran en el viewport.

  threshold: 0.1 = el 10% del elemento debe ser visible.
  rootMargin: "0px 0px -50px" = activa 50px ANTES de que sea visible
  (para que la animación empiece un poco antes y se vea más natural).
-->
<script>
  function initScrollAnimations() {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            observer.unobserve(entry.target); // Solo animar una vez
          }
        });
      },
      { threshold: 0.1, rootMargin: "0px 0px -50px 0px" }
    );

    document.querySelectorAll(".animate-on-scroll").forEach((el) => {
      observer.observe(el);
    });
  }

  // Ejecutar al cargar y después de cada View Transition
  initScrollAnimations();
  document.addEventListener("astro:after-swap", initScrollAnimations);
</script>
