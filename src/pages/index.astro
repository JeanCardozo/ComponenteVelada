---
/**
 * Página principal — El orquestador.
 *
 * CONCEPTO: Composición de secciones.
 *
 * Fíjate qué limpio queda este archivo. Cada sección es un componente
 * independiente que se importa y se coloca en orden.
 *
 * Si mañana quieres cambiar el orden (poner Combates antes que Boxeadores),
 * solo mueves una línea. Si quieres añadir una sección de Sponsors,
 * importas y la colocas donde quieras.
 *
 * El repo oficial hace EXACTAMENTE esto en su index.astro:
 * importa Header, Hero, Countdown, Sponsors, etc. y los compone.
 *
 * NOTA sobre el Countdown:
 * Se importa directamente aquí (no en una sección separada) porque
 * va dentro del Hero. Se usa client:visible para que solo cargue JS
 * cuando el usuario ve la página (que es inmediato porque está arriba).
 */

import Layout from "@/layouts/Layout.astro";
import Header from "@components/astro/Header.astro";
import Footer from "@components/astro/Footer.astro";
import Hero from "@sections/Hero.astro";
import Fighters from "@sections/Fighters.astro";
import Combats from "@sections/Combats.astro";
import Voting from "@sections/Voting.astro";
import Countdown from "@components/react/Countdown";
---

<Layout>
  <Header />

  <main>
    <Hero />

    <!-- Countdown — Isla React con client:visible -->
    <section class="py-12 px-4 -mt-20 relative z-10">
      <div class="max-w-2xl mx-auto">
        <p class="text-center text-sm uppercase tracking-wider text-zinc-500 mb-6">
          Faltan
        </p>
        <Countdown client:visible targetDate="2026-07-25T20:00:00+02:00" />
      </div>
    </section>

    <Fighters />
    <Combats />
    <Voting />
  </main>

  <Footer />
</Layout>
